{
  "name": "fnirs-webpipe",
  "version": "0.2.3",
  "private": true,
  "type": "module",
  "scripts": {
    "codex": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/codex-session.ps1",
    "codex:new": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/codex-session.ps1 -New",
    "codex:pick": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/codex-session.ps1 -Picker",
    "git:add": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/git-add.ps1",
    "git:delete-branch": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/git-delete-branch.ps1",
    "git:push": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/git-push-main.ps1",
    "git:save": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/git-save.ps1",
    "git:status": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/git-status.ps1",
    "serve": "node scripts/dev-server.mjs",
    "ui:capture": "node scripts/capture-ui.mjs",
    "ui:capture:light": "node scripts/capture-ui.mjs --theme light",
    "ui:install": "playwright install chromium"
  },
  "devDependencies": {
    "playwright": "^1.53.0"
  }
}
